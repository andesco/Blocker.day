{
  "name": "blocker-day",
  "version": "0.1.0",
  "description": "Blocker.day is a Cloudflare Worker that generates a .ics calendar feed to create deterministic blocks of time",
  "main": "index.js",
  "scripts": {
    "build:readme": "node scripts/build-readme.js",
